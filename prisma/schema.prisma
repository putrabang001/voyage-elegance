generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("superadmin") // superadmin only
  lastLogin    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  activityLogs ActivityLog[]
}

// ============================================
// CONTENT MODELS
// ============================================

model Destination {
  id                String   @id @default(cuid())
  slug              String   @unique
  region            String
  featured          Boolean  @default(false)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Multi-language fields
  nameEn            String
  nameFr            String
  nameId            String
  locationEn        String
  locationFr        String
  locationId        String
  shortDescEn      String
  shortDescFr      String
  shortDescId      String
  descriptionEn    String
  descriptionFr    String
  descriptionId    String
  highlightsEn      String   // JSON array stored as string
  highlightsFr      String
  highlightsId      String

  // Relations
  images            DestinationImage[]
  tours             Tour[]
  faqs              FAQ[]

  @@map("destinations")
}

model DestinationImage {
  id            String      @id @default(cuid())
  destinationId String
  url           String
  altEn         String
  altFr         String
  altId         String
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())

  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@map("destination_images")
}

model Tour {
  id                String   @id @default(cuid())
  slug              String   @unique
  destinationId      String
  featured          Boolean  @default(false)
  sortOrder         Int      @default(0)
  duration          String   // e.g., "5 Days / 4 Nights"
  price             Float
  currency          String   @default("USD")
  groupSizeMin       Int      @default(1)
  groupSizeMax       Int      @default(12)
  difficulty         String   @default("easy") // easy, moderate, challenging
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Multi-language fields
  nameEn            String
  nameFr            String
  nameId            String
  shortDescEn      String
  shortDescFr      String
  shortDescId      String
  descriptionEn    String
  descriptionFr    String
  descriptionId    String
  itineraryEn      String   // JSON array stored as string
  itineraryFr      String
  itineraryId      String
  includesEn       String   // JSON array stored as string
  includesFr       String
  includesId       String
  excludesEn       String   // JSON array stored as string
  excludesFr       String
  excludesId       String

  // Relations
  images            TourImage[]
  destination       Destination @relation(fields: [destinationId], references: [id])
  testimonials      Testimonial[]
  inquiries         Inquiry[]

  @@map("tours")
}

model TourImage {
  id          String   @id @default(cuid())
  tourId      String
  url         String
  altEn       String
  altFr       String
  altId       String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  tour        Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@map("tour_images")
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  category    String
  featured    Boolean  @default(false)
  published   Boolean  @default(true)
  author      String
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Multi-language fields
  titleEn     String
  titleFr     String
  titleId     String
  excerptEn   String
  excerptFr   String
  excerptId   String
  contentEn   String
  contentFr   String
  contentId   String

  image       String
  altEn       String
  altFr       String
  altId       String

  @@map("blog_posts")
}

model Testimonial {
  id          String   @id @default(cuid())
  tourId      String?
  featured    Boolean  @default(false)
  rating      Int      @default(5) // 1-5 stars
  createdAt   DateTime @default(now())

  name        String
  location    String
  avatar      String?
  quoteEn     String
  quoteFr     String
  quoteId     String

  tour        Tour?    @relation(fields: [tourId], references: [id])

  @@map("testimonials")
}

model FAQ {
  id            String   @id @default(cuid())
  destinationId String?
  category      String   @default("general")
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Multi-language fields
  questionEn   String
  questionFr   String
  questionId   String
  answerEn     String
  answerFr     String
  answerId     String

  destination   Destination? @relation(fields: [destinationId], references: [id])

  @@map("faqs")
}

model GalleryImage {
  id          String   @id @default(cuid())
  url         String
  category    String   @default("all") // underwater, beach, sunset, wildlife, all
  altEn       String
  altFr       String
  altId       String
  captionEn   String?
  captionFr   String?
  captionId   String?
  sortOrder   Int      @default(0)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("gallery_images")
}

// ============================================
// COMMUNICATION & FORMS
// ============================================

model Inquiry {
  id          String   @id @default(cuid())
  tourId      String?
  name        String
  email       String
  phone       String?
  destination String?
  tour        String?
  message     String
  status      String   @default("new") // new, read, replied, closed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tourRel     Tour?    @relation(fields: [tourId], references: [id])

  @@map("inquiries")
}

// ============================================
// SETTINGS & LOGS
// ============================================

model ActivityLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String   // create, update, delete, login, logout
  entity      String   // destinations, tours, blog, etc.
  entityId    String?
  details     String?
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())

  admin       Admin    @relation(fields: [adminId], references: [id])

  @@map("activity_logs")
}

model SiteSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  valueEn     String?
  valueFr     String?
  valueId     String?
  updatedAt   DateTime @updatedAt

  @@map("site_settings")
}
